    "## 4. Word Clouds por Sentimiento"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ─── WORD CLOUDS ─────────────────────────────────────────────────────────────\n",
    "fig, axes = plt.subplots(1, 3, figsize=(16, 5))\n",
    "configs = [\n",
    "    ('POSITIVO', '#27AE60', 'Greens'),\n",
    "    ('NEUTRO',   '#7F8C8D', 'Greys'),\n",
    "    ('NEGATIVO', '#E74C3C', 'Reds'),\n",
    "]\n",
    "\n",
    "for ax, (sentimiento, color, cmap) in zip(axes, configs):\n",
    "    textos = ' '.join(df[df['sentimiento'] == sentimiento]['texto_limpio'])\n",
    "    if textos.strip():\n",
    "        wc = WordCloud(\n",
    "            width=600, height=300,\n",
    "            background_color='white',\n",
    "            colormap=cmap,\n",
    "            max_words=40,\n",
    "            min_font_size=10,\n",
    "            collocations=False\n",
    "        ).generate(textos)\n",
    "        ax.imshow(wc, interpolation='bilinear')\n",
    "    ax.axis('off')\n",
    "    ax.set_title(f'Noticias {sentimiento}\\n({(df[\"sentimiento\"]==sentimiento).sum()} titulares)',\n",
    "                  fontweight='bold', color=color)\n",
    "\n",
    "plt.suptitle('Word Clouds por Sentimiento — Noticias Financieras LATAM',\n",
    "              fontweight='bold', y=1.02)\n",
    "plt.tight_layout()\n",
    "plt.savefig('img/02_wordclouds.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()"
