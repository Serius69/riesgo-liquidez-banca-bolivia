    "warnings.filterwarnings('ignore')\n",
    "\n",
    "# Descargar recursos NLTK necesarios\n",
    "for recurso in ['punkt', 'stopwords', 'averaged_perceptron_tagger', 'punkt_tab']:\n",
    "    nltk.download(recurso, quiet=True)\n",
