  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. Clasificación de Categorías con TF-IDF"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ─── TF-IDF + CLASIFICACIÓN ───────────────────────────────────────────────────\n",
    "# TF-IDF: Term Frequency-Inverse Document Frequency\n",
    "# Peso a cada palabra según qué tan única es en ese documento vs el corpus\n",
    "# Ideal para clasificación de texto cuando no hay suficientes datos para deep learning\n",
    "\n",
    "# Agrupar categorías poco frecuentes\n",
    "df['categoria_agrupada'] = df['categoria'].replace({\n",
    "    'energia': 'macroeconomia',\n",
    "    'comercio': 'macroeconomia',\n",
    "    'finanzas_publicas': 'macroeconomia',\n",
    "    'banca': 'fintech'\n",
    "})\n",
    "\n",
    "X = df['texto_limpio']\n",
    "y = df['categoria_agrupada']\n",
    "\n",
    "X_train, X_test, y_train, y_test = train_test_split(\n",
    "    X, y, test_size=0.25, random_state=SEED, stratify=y\n",
    ")\n",
    "\n",
    "# Pipeline: TF-IDF → Logistic Regression\n",
    "pipeline_clf = Pipeline([\n",
    "    ('tfidf', TfidfVectorizer(\n",
    "        ngram_range=(1, 2),      # Unigramas y bigramas\n",
    "        max_features=500,\n",
    "        min_df=1,\n",
    "        sublinear_tf=True        # Escala logarítmica de TF\n",
    "    )),\n",
    "    ('clf', LogisticRegression(max_iter=1000, random_state=SEED, C=1.0))\n",
    "])\n",
    "\n",
    "pipeline_clf.fit(X_train, y_train)\n",
    "pred = pipeline_clf.predict(X_test)\n",
    "\n",
    "print('Clasificación de categorías — TF-IDF + Logistic Regression')\n",
    "print('='*60)\n",
    "print(classification_report(y_test, pred, zero_division=0))\n",
    "\n",
    "# Cross-validation\n",
    "cv_scores = cross_val_score(pipeline_clf, X, y, cv=3, scoring='accuracy')\n",
    "print(f'Cross-validation accuracy: {cv_scores.mean():.3f} ± {cv_scores.std():.3f}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ─── PALABRAS MÁS DISCRIMINATIVAS POR CATEGORÍA ───────────────────────────────\n",
    "tfidf      = pipeline_clf.named_steps['tfidf']\n",
    "clf        = pipeline_clf.named_steps['clf']\n",
    "categorias = clf.classes_\n",
    "vocab      = tfidf.get_feature_names_out()\n",
    "\n",
    "fig, axes = plt.subplots(1, len(categorias), figsize=(16, 5))\n",
    "if len(categorias) == 1:\n",
    "    axes = [axes]\n",
    "\n",
    "for ax, (cat, coefs) in zip(axes, zip(categorias, clf.coef_)):\n",
    "    top_idx = np.argsort(coefs)[-10:]\n",
    "    top_palabras  = vocab[top_idx]\n",
    "    top_coefs = coefs[top_idx]\n",
    "\n",
    "    colores = ['#2E86C1' if c > 0 else '#E74C3C' for c in top_coefs]\n",
    "    ax.barh(top_palabras, top_coefs, color=colores, alpha=0.85)\n",
    "    ax.set_title(f'{cat.upper()}', fontweight='bold', fontsize=10)\n",
    "    ax.set_xlabel('Coeficiente LR')\n",
    "    ax.tick_params(labelsize=8)\n",
    "\n",
    "plt.suptitle('Palabras Más Discriminativas por Categoría (TF-IDF + LR)',\n",
    "              fontweight='bold', y=1.02)\n",
    "plt.tight_layout()\n",
    "plt.savefig('img/03_palabras_discriminativas.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()"
   ]
  },
