    "## 2. Preprocesamiento de Texto en Español"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ─── PREPROCESAMIENTO ─────────────────────────────────────────────────────────\n",
    "STOPWORDS_ES = set(stopwords.words('spanish'))\n",
    "\n",
    "# Stopwords financieras adicionales (palabras comunes pero sin valor semántico)\n",
    "STOPWORDS_FINANCIERAS = {\n",
    "    'millones', 'miles', 'según', 'señaló', 'informó', 'indicó',\n",
    "    'dijo', 'aseguró', 'afirmó', 'nuevo', 'nueva', 'año', 'mes',\n",
    "    'trimestre', 'semestre', 'datos', 'cifras', 'reporte', 'informe'\n",
    "}\n",
    "STOPWORDS_TODAS = STOPWORDS_ES | STOPWORDS_FINANCIERAS\n",
    "\n",
    "stemmer = SnowballStemmer('spanish')\n",
    "\n",
    "def preprocesar_texto(texto: str, stemming: bool = False) -> str:\n",
    "    \"\"\"\n",
    "    Limpia y normaliza texto financiero en español.\n",
    "    1. Minúsculas\n",
    "    2. Eliminar puntuación y números\n",
    "    3. Tokenizar\n",
    "    4. Eliminar stopwords\n",
    "    5. Stemming opcional\n",
    "    \"\"\"\n",
    "    # Minúsculas\n",
    "    texto = texto.lower()\n",
    "    # Eliminar caracteres especiales pero mantener letras con tilde\n",
    "    texto = re.sub(r'[^a-záéíóúüñ\\s]', ' ', texto)\n",
    "    # Tokenizar\n",
    "    tokens = word_tokenize(texto, language='spanish')\n",
    "    # Filtrar stopwords y tokens cortos\n",
    "    tokens = [t for t in tokens if t not in STOPWORDS_TODAS and len(t) > 2]\n",
    "    # Stemming opcional\n",
    "    if stemming:\n",
    "        tokens = [stemmer.stem(t) for t in tokens]\n",
    "    return ' '.join(tokens)\n",
    "\n",
    "df['texto_limpio'] = df['titulo'].apply(preprocesar_texto)\n",
    "df['tokens']       = df['texto_limpio'].str.split()\n",
    "df['n_tokens']     = df['tokens'].apply(len)\n",
    "\n",
    "print('Ejemplos de preprocesamiento:')\n",
    "for i in range(3):\n",
    "    print(f'\\nOriginal: {df[\"titulo\"].iloc[i]}')\n",
    "    print(f'Limpio:   {df[\"texto_limpio\"].iloc[i]}')"
   ]
