    "## 7. Correlación Sentimiento vs Precio BTC"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ─── SENTIMIENTO vs PRECIO ────────────────────────────────────────────────────\n",
    "# Correlacionar el sentimiento de noticias cripto con el precio de BTC\n",
    "# Hipótesis: noticias positivas sobre cripto preceden a subidas de precio\n",
    "\n",
    "import yfinance as yf\n",
    "\n",
    "btc = yf.download('BTC-USD',\n",
    "                   start=df['fecha'].min() - pd.Timedelta(days=5),\n",
    "                   end=df['fecha'].max()   + pd.Timedelta(days=5),\n",
    "                   auto_adjust=True)['Close']\n",
    "btc_ret = btc.pct_change() * 100\n",
    "\n",
    "# Sentimiento diario de noticias cripto\n",
    "sent_diario = df.groupby('fecha')['score_final'].mean()\n",
    "\n",
    "# Combinar en DataFrame común\n",
    "df_corr = pd.DataFrame({\n",
    "    'sentimiento': sent_diario,\n",
    "    'btc_retorno': btc_ret.reindex(sent_diario.index)\n",
    "}).dropna()\n",
    "\n",
    "if len(df_corr) >= 3:\n",
    "    corr_val = df_corr['sentimiento'].corr(df_corr['btc_retorno'])\n",
    "\n",
    "    fig, axes = plt.subplots(1, 2, figsize=(14, 5))\n",
    "\n",
    "    # Scatter\n",
    "    axes[0].scatter(df_corr['sentimiento'], df_corr['btc_retorno'],\n",
    "                     color='#F7931A', alpha=0.8, s=80, edgecolors='white')\n",
    "    # Línea de tendencia\n",
    "    if len(df_corr) >= 2:\n",
    "        z = np.polyfit(df_corr['sentimiento'], df_corr['btc_retorno'], 1)\n",
    "        p = np.poly1d(z)\n",
    "        x_line = np.linspace(df_corr['sentimiento'].min(), df_corr['sentimiento'].max(), 50)\n",
    "        axes[0].plot(x_line, p(x_line), 'r--', lw=2)\n",
    "    axes[0].axhline(0, color='black', lw=0.8); axes[0].axvline(0, color='black', lw=0.8)\n",
    "    axes[0].set_xlabel('Score de Sentimiento Noticias')\n",
    "    axes[0].set_ylabel('Retorno BTC (%)')\n",
    "    axes[0].set_title(f'Sentimiento vs Retorno BTC\\nCorrelación: {corr_val:.3f}', fontweight='bold')\n",
    "\n",
    "    # Serie de tiempo\n",
    "    ax2 = axes[1]\n",
    "    ax2_r = ax2.twinx()\n",
    "    ax2.bar(df_corr.index, df_corr['sentimiento'],\n",
    "             color=['#27AE60' if v > 0 else '#E74C3C' for v in df_corr['sentimiento']],\n",
    "             alpha=0.6, label='Sentimiento')\n",
    "    ax2_r.plot(btc.index, btc.values, color='#F7931A', lw=2, label='BTC precio')\n",
    "    ax2.set_ylabel('Score sentimiento', color='#2E86C1')\n",
    "    ax2_r.set_ylabel('Precio BTC (USD)', color='#F7931A')\n",
    "    ax2.set_title('Sentimiento de Noticias vs Precio BTC', fontweight='bold')\n",
    "\n",
    "    plt.tight_layout()\n",
    "    plt.savefig('img/04_sentimiento_vs_precio.png', dpi=150, bbox_inches='tight')\n",
    "    plt.show()\n",
    "\n",
    "    print(f'\\n📊 Correlación sentimiento noticias vs retorno BTC: {corr_val:.4f}')\n",
    "    print('💡 Nota: Con pocas observaciones, la correlación es orientativa.')\n",
    "    print('   Para un estudio robusto se necesitan al menos 100+ noticias diarias.')\n",
    "else:\n",
    "    print('⚠️  Pocas fechas coincidentes para el análisis de correlación.')"
