   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 6. Topic Modeling con LDA"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ─── LDA: LATENT DIRICHLET ALLOCATION ────────────────────────────────────────\n",
    "# LDA descubre temas latentes en el corpus sin necesitar etiquetas\n",
    "# Cada documento es una mezcla de temas, cada tema es una distribución de palabras\n",
    "\n",
    "N_TOPICS = 4\n",
    "\n",
    "vectorizer_lda = CountVectorizer(\n",
    "    max_features=300,\n",
    "    min_df=1,\n",
    "    ngram_range=(1, 2)\n",
    ")\n",
    "X_lda = vectorizer_lda.fit_transform(df['texto_limpio'])\n",
    "vocab_lda = vectorizer_lda.get_feature_names_out()\n",
    "\n",
    "lda = LatentDirichletAllocation(\n",
    "    n_components=N_TOPICS,\n",
    "    random_state=SEED,\n",
    "    max_iter=50,\n",
    "    learning_method='online'\n",
    ")\n",
    "lda.fit(X_lda)\n",
    "\n",
    "# Top palabras por tema\n",
    "N_PALABRAS_TEMA = 8\n",
    "nombres_temas = ['Macroeconomía Bolivia', 'Fintech & Pagos', 'Cripto & Digital', 'Regulación']\n",
    "\n",
    "print('Temas descubiertos por LDA:')\n",
    "print('='*60)\n",
    "for i, (topic, nombre) in enumerate(zip(lda.components_, nombres_temas)):\n",
    "    top_idx = topic.argsort()[-N_PALABRAS_TEMA:][::-1]\n",
    "    palabras = ', '.join(vocab_lda[top_idx])\n",
    "    print(f'\\nTema {i+1} — {nombre}:')\n",
    "    print(f'  {palabras}')\n",
    "\n",
    "# Asignar tema dominante a cada noticia\n",
    "doc_topics = lda.transform(X_lda)\n",
    "df['tema_lda'] = doc_topics.argmax(axis=1)\n",
    "df['tema_nombre'] = df['tema_lda'].map({i: n for i, n in enumerate(nombres_temas)})\n",
    "\n",
    "print(f'\\nDistribución por tema:')\n",
    "print(df['tema_nombre'].value_counts().to_string())"
   ]
  },
