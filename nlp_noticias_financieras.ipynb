   "source": [
    "## 3. Análisis de Sentimiento"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ─── SENTIMIENTO: VADER + TEXTBLOB ────────────────────────────────────────────\n",
    "# VADER: diseñado para texto de noticias y redes sociales\n",
    "# TextBlob: análisis de polaridad general\n",
    "# Combinamos ambos para mayor robustez\n",
    "\n",
    "analyzer = SentimentIntensityAnalyzer()\n",
    "\n",
    "# Diccionario financiero en español para VADER\n",
    "# Palabras positivas y negativas específicas del contexto financiero\n",
    "lexicon_financiero = {\n",
    "    # Positivas financieras\n",
    "    'superávit': 3.0, 'crecimiento': 2.5, 'récord': 2.0, 'ganancias': 2.5,\n",
    "    'inversión': 1.5, 'expansión': 2.0, 'adopción': 1.5, 'supera': 2.0,\n",
    "    'lider': 2.0, 'aprueba': 1.5, 'reporta': 0.5, 'alcanza': 1.0,\n",
    "    'exitoso': 2.5, 'recuperación': 2.0, 'crecen': 2.0, 'aumenta': 1.5,\n",
    "    # Negativas financieras\n",
    "    'caen': -2.5, 'caída': -2.5, 'crisis': -3.0, 'escasez': -2.5,\n",
    "    'devaluación': -3.0, 'inflación': -2.0, 'fraude': -3.5, 'suspende': -2.0,\n",
    "    'mínimo': -2.0, 'contracción': -2.5, 'deuda': -1.5, 'déficit': -2.5,\n",
    "    'congela': -2.5, 'cierre': -2.0, 'enfrenta': -1.5, 'preocupando': -2.0,\n",
    "}\n",
    "analyzer.lexicon.update(lexicon_financiero)\n",
    "\n",
    "def analizar_sentimiento(texto: str) -> dict:\n",
    "    \"\"\"Combina VADER y TextBlob para análisis de sentimiento más robusto.\"\"\"\n",
    "    # VADER\n",
    "    scores_vader = analyzer.polarity_scores(texto)\n",
    "\n",
    "    # TextBlob (funciona mejor en inglés, pero da señal útil)\n",
    "    blob = TextBlob(texto)\n",
    "    polaridad_tb = blob.sentiment.polarity\n",
    "\n",
    "    # Score combinado (promedio ponderado)\n",
    "    score_combinado = 0.7 * scores_vader['compound'] + 0.3 * polaridad_tb\n",
    "\n",
    "    # Etiqueta\n",
    "    if score_combinado >= 0.05:\n",
    "        etiqueta = 'POSITIVO'\n",
    "    elif score_combinado <= -0.05:\n",
    "        etiqueta = 'NEGATIVO'\n",
    "    else:\n",
    "        etiqueta = 'NEUTRO'\n",
    "\n",
    "    return {\n",
    "        'score_vader':    round(scores_vader['compound'], 4),\n",
    "        'score_textblob': round(polaridad_tb, 4),\n",
    "        'score_final':    round(score_combinado, 4),\n",
    "        'sentimiento':    etiqueta\n",
    "    }\n",
    "\n",
    "# Aplicar a todo el dataset\n",
    "sentimientos = df['titulo'].apply(analizar_sentimiento)\n",
    "df = pd.concat([df, pd.DataFrame(sentimientos.tolist())], axis=1)\n",
    "\n",
    "print('Distribución de sentimientos:')\n",
    "print(df['sentimiento'].value_counts())\n",
    "print(f'\\nScore promedio: {df[\"score_final\"].mean():.4f}')\n",
    "print('\\nEjemplos:')\n",
    "for _, row in df.head(5).iterrows():\n",
    "    emoji = '🟢' if row['sentimiento']=='POSITIVO' else ('🔴' if row['sentimiento']=='NEGATIVO' else '⚪')\n",
    "    print(f'  {emoji} [{row[\"score_final\"]:+.3f}] {row[\"titulo\"][:70]}...')"
   ]
